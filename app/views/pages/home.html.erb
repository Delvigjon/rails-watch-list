<header class="home-hero">
  <%= image_tag "watchlist.webp", alt: "Univers cinéma", class: "home-hero__image" %>
  <div class="home-hero__overlay"></div>

  <div class="home-hero__content">
    <p class="home-hero__eyebrow">Ma watchlist cinéma</p>
    <h1 class="home-hero__title">Organise tes films préférés simplement</h1>
    <p class="home-hero__text">
      Crée tes listes, retrouve les films les plus populaires et garde une vraie vue d’ensemble sur ce que tu veux regarder.
    </p>

    <div class="home-hero__actions">
      <%= link_to "Créer une liste", new_list_path, class: "home-button home-button--primary" %>
      <%= link_to "Voir mes listes", lists_path, class: "home-button home-button--secondary" %>
    </div>
  </div>
</header>

<main class="home-page" data-controller="movies">
  <section class="home-section home-section--intro">
    <div class="home-container">
      <div class="home-intro">
        <h2 class="home-section__title">Une watchlist claire et agréable</h2>
        <p class="home-section__text">
          Parcours des films tendances, découvre les mieux notés et construis tes propres sélections dans une interface sobre, lisible et moderne.
        </p>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-container">
      <div class="home-section__header">
        <h2 class="home-section__title">Tendances du moment</h2>
        <p class="home-section__text">Les films qui attirent le plus l’attention en ce moment.</p>
      </div>

      <div class="home-movies-grid" data-movies-target="trending"></div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-container">
      <div class="home-section__header">
        <h2 class="home-section__title">Les mieux notés</h2>
        <p class="home-section__text">Une sélection de films plébiscités par le public.</p>
      </div>

      <div class="home-movies-grid" data-movies-target="topRated"></div>
    </div>
  </section>
</main>
