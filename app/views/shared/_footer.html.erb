<footer class="site-footer">
  <div class="site-footer__container">

    <!-- Bloc marque -->
    <div class="site-footer__brand">
      <%= image_tag "watchlist-logo.png", alt: "Logo Watchlist", class: "site-footer__logo" %>
      <p class="site-footer__description">
        RailsWatchList — organise tes films, découvre les tendances et garde une vue claire sur ce que tu veux regarder.
      </p>
    </div>

    <!-- Liens -->
    <div class="site-footer__links">
      <h4 class="site-footer__title">Navigation</h4>
      <ul>
        <li><%= link_to "Accueil", root_path %></li>
        <li><%= link_to "Mes listes", lists_path %></li>
        <li><a href="#">Contact</a></li>
        <li><a href="#">À propos</a></li>
      </ul>
    </div>

    <!-- Réseaux -->
    <div class="site-footer__social">
      <h4 class="site-footer__title">Suivez-nous</h4>

      <div class="site-footer__icons">
        <a href="#" class="site-footer__icon">
          <i class="fab fa-facebook-f"></i>
        </a>
        <a href="#" class="site-footer__icon">
          <i class="fab fa-twitter"></i>
        </a>
        <a href="#" class="site-footer__icon">
          <i class="fab fa-instagram"></i>
        </a>
      </div>
    </div>

  </div>

  <!-- Bas -->
  <div class="site-footer__bottom">
    <p>© <%= Time.current.year %> RailsWatchList — Tous droits réservés</p>
  </div>
</footer>
